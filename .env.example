# =============================================================================
# OCELOT WALLET - TAURI DESKTOP APPLICATION CONFIGURATION
# =============================================================================
# Copy this file to .env and configure for your environment
#
# Architecture Overview:
# - Tauri Desktop App (Rust backend + SvelteKit frontend)
# - Wallet files managed locally by Tauri (encrypted .wallet files)
# - RPC calls for balance queries and transaction broadcasting
# - No direct database connection from the wallet
# =============================================================================

# Transaction API Configuration
# ================================
# The wallet uses RPC-backed services for blockchain data and transaction broadcasting.

# Transaction API endpoint (default: http://localhost:8080)
ZEICOIN_TRANSACTION_API_URL=http://localhost:8080

# Request timeout in milliseconds
ZEICOIN_TRANSACTION_API_TIMEOUT=10000

# Public environment variables (exposed to browser)
PUBLIC_TRANSACTION_API_URL=http://localhost:8080

# =============================================================================
# NOTES
# =============================================================================
#
# Removed Components (No Longer Used):
# - CLI Bridge (replaced by Tauri IPC)
# - REST API endpoints (replaced by Tauri commands)
# - PostgreSQL direct access
# - Wallet discovery service (Tauri handles via filesystem)
# - SQLite cache (Tauri is fast enough)
# - JWT authentication (session-based in Tauri)
#
# Wallet Files:
# - Managed by Tauri in standard OS locations
# - No configuration needed (Tauri handles paths automatically)
# - Encrypted with Argon2id + AES-256-GCM
#
# =============================================================================
